import Doc from '@theme/layouts/Doc.astro';
---
<Doc title="Not found" slug="" hero={true} description="Page not found (404)">
  <section class="hero">
    <p class="eyebrow">Error 404</p>
    <h1>This page went missing</h1>
    <p class="notfound-text">The page you were looking for doesn't exist or has moved. Try the search in the top bar, or head back home.</p>
    <a class="hero-enter" href="/">Back home<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"></path><path d="M13 6l6 6-6 6"></path></svg></a>
  </section>
</Doc>
